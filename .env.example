# --- Frontend (Vite) ---
# Dev: `/api/*` -> Django runserver (asosiy backend).
VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# API: devda `/api` (Vite proksi). Prod: to'liq URL, masalan https://api.domen.com/api
# VITE_API_BASE=/api

# --- Telegram Mini App ---
# Bot token FAQAT server/muhitda (gitga qo'shmang). Tekshirish: npm run telegram:verify
# TELEGRAM_BOT_TOKEN=
# Mini App HTTPS domeningiz (vergul bilan): Django CORS/CSRF
# CORS_EXTRA_ORIGINS=https://sizning-mini-app.domen
# CSRF_TRUSTED_EXTRA=https://sizning-mini-app.domen
# Tunnel (ngrok): https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=
# TUNNEL_PORT=8081 npm run public:tunnel
