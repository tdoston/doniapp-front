# --- Frontend (Vite) ---
# Dev: `/api/*` -> Django runserver (asosiy backend).
VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# API: devda `/api` (Vite proksi). Prod: to'liq URL, masalan https://api.domen.com/api
# VITE_API_BASE=/api
# Yoki faqat origin (app `/api` qo'shadi):
# VITE_API_URL=https://<railway-backend-domain>
# CRA: REACT_APP_API_URL=https://...
# Railway frontend: `.env.production` yoki Variables (build vaqtida)
# VITE_API_BASE=https://doniapp-back-production.up.railway.app/api
# VITE_TELEGRAM_LOGIN_BOT=hosteluzbot

# --- Telegram Mini App ---
# Login Widget (brauzer): BotFather bot @username — @ siz, masalan hosteluzbot
# VITE_TELEGRAM_LOGIN_BOT=hosteluzbot
# Bot token FAQAT server/muhitda (gitga qo'shmang). Tekshirish: npm run telegram:verify
# TELEGRAM_BOT_TOKEN=
# Kanalga bron/check-in xabarlari (backend `django_backend/.env` yoki Railway Variables)
# Production kanal ID: TELEGRAM_NOTIFY_CHAT_ID=-1003942993894
# Lokal test: TELEGRAM_CHANNEL_ID_TEST=... (django_backend/.env)
# TELEGRAM_NOTIFY_CHAT_ID=-1003942993894
# Mini App HTTPS domeningiz (vergul bilan): Django CORS/CSRF
# CORS_EXTRA_ORIGINS=https://sizning-mini-app.domen
# CSRF_TRUSTED_EXTRA=https://sizning-mini-app.domen
# Railway: boshqa *.up.railway.app frontlar uchun avtomatik CORS regex (staging qulayligi).
# Faqat aniq domenlar: CORS_STRICT_RAILWAY=1
# CORS_STRICT_RAILWAY=1
# Tunnel (ngrok): https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=
# TUNNEL_PORT=8081 npm run public:tunnel
